{
  "name": "monk",
  "version": "1.0.0",
  "description": "A Typora-like Markdown editor with real-time preview",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "build:mac": "vite build && electron-builder --mac",
    "start": "electron .",
    "open": "electron .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.monk.editor",
    "productName": "Monk",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown",
        "role": "Editor"
      }
    ]
  },
  "dependencies": {
    "@tiptap/extension-blockquote": "^3.20.0",
    "@tiptap/extension-bold": "^3.20.0",
    "@tiptap/extension-bullet-list": "^3.20.0",
    "@tiptap/extension-code": "^3.20.0",
    "@tiptap/extension-code-block": "^3.20.0",
    "@tiptap/extension-emoji": "^3.20.0",
    "@tiptap/extension-heading": "^3.20.0",
    "@tiptap/extension-horizontal-rule": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-italic": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-ordered-list": "^3.20.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/extension-table-cell": "^3.20.0",
    "@tiptap/extension-table-header": "^3.20.0",
    "@tiptap/extension-table-row": "^3.20.0",
    "@tiptap/extension-task-item": "^3.20.0",
    "@tiptap/extension-task-list": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "markdown-it": "^14.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "jsdom": "^14.1.0",
    "vite": "^5.4.21",
    "vitest": "^1.6.1",
    "wait-on": "^7.2.0"
  }
}
